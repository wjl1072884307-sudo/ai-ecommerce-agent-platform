# Local development environment for ai-ecommerce-agent-platform.
# Copy this file to .env and adjust values for your machine.

APP_ENV=development
APP_NAME=AI Ecommerce Agent Platform API
DEBUG=true

DATABASE_URL=sqlite:///./backend/data/app.db
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

LLM_PROVIDER=mock
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=mock-agent
LLM_TIMEOUT_SECONDS=15
RAG_RETRIEVER=keyword

LOG_LEVEL=INFO
BACKEND_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Docker Compose defaults.
POSTGRES_DB=ai_ecommerce
POSTGRES_USER=ai_ecommerce
POSTGRES_PASSWORD=ai_ecommerce_password
POSTGRES_PORT=5432
BACKEND_PORT=8000
FRONTEND_PORT=8080
